<test>
    <settings>
        <max_memory_usage>30000000000</max_memory_usage>
    </settings>

    <substitutions>
        <substitution>
           <name>col</name>
           <values>
               <value>UserID</value>
               <value>SearchEngineID</value>
               <value>RegionID</value>
               <value>SearchPhrase</value>
               <value>ClientIP</value>
           </values>
        </substitution>
        <substitution>
           <name>func</name>
           <values>
               <value>uniq</value>
               <value>uniqExact</value>
               <value>uniqHLL12</value>
               <value>uniqCombined(12)</value>
               <value>uniqCombined(14)</value>
               <value>uniqCombined(16)</value>
               <value>uniqCombined(18)</value>
               <value>uniqCombined64(12)</value>
               <value>uniqCombined64(14)</value>
               <value>uniqCombined64(16)</value>
               <value>uniqCombined64(18)</value>
               <value>uniqUpTo(3)</value>
               <value>uniqUpTo(5)</value>
               <value>uniqUpTo(10)</value>
               <value>uniqUpTo(25)</value>
               <value>uniqUpTo(100)</value>
           </values>
       </substitution>
    </substitutions>

    <query>SELECT {func}({col}) FROM hits_100m_single FORMAT Null</query>
    <query>SELECT uniqTheta({col}) FROM hits_10m_single FORMAT Null</query>
</test>
